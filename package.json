{
  "name": "float-folder",
  "version": "1.0.0",
  "description": "FloatFolder - 轻量级桌面悬浮文件夹工具，一键访问常用文件，拖拽即用，实时同步",
  "author": "FloatFolder",
  "license": "MIT",
  "homepage": "https://github.com/floatfolder/float-folder#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/floatfolder/float-folder.git"
  },
  "bugs": {
    "url": "https://github.com/floatfolder/float-folder/issues"
  },
  "keywords": [
    "electron",
    "desktop",
    "file-manager",
    "floating-window",
    "productivity",
    "react",
    "typescript"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:vite": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "com.floatfolder.app",
    "productName": "FloatFolder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "shortcutName": "FloatFolder"
    }
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  }
}
